{
  "schemaVersion": 1,
  "id": "fs.sovereign.tasks",
  "name": "Tasks",
  "version": "0.11.0",
  "description": "A minimal, privacy-first task manager.",
  "type": "sovereign",
  "runtime": "native",
  "routePrefix": "/tasks",
  "shell": "default",
  "icon": "icon.svg",
  "database": "shared",
  "permissions": ["auth:session", "db:readWrite", "notifications:send"],
  "schedules": [
    { "id": "due-reminders", "intervalMinutes": 1, "entry": "app/_jobs/due-reminders.ts" }
  ],
  "repository": "https://github.com/sovereignfs/sovereign-tasks",
  "compatibility": {
    "minPlatformVersion": "0.19.0"
  }
}
